{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u30de\u30fc\u30af\u30c0\u30a6\u30f3\u304b\u3089WEB\u30da\u30fc\u30b8(wiki)\u3078 (Doc as a Code)","text":"<p>\u30a8\u30b0\u30bc\u30af\u30c6\u30a3\u30d6\u30fb\u30b5\u30de\u30ea\u30fc</p> <p>\u672c\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u306f\u3001\u5168\u793e\u306e\u6280\u8853\u8cc7\u7523\u30fb\u30ce\u30a6\u30cf\u30a6\u3092\u300c\u30b3\u30fc\u30c9\u300d\u3068\u3057\u3066\u7ba1\u7406\u3059\u308b\u3053\u3068\u3067\u3001\u60c5\u5831\u306e\u9673\u8150\u5316\u3092\u9632\u304e\u3001\u958b\u793a\u30b9\u30d4\u30fc\u30c9\u3092300%\u5411\u4e0a\u3055\u305b\u308b\u3053\u3068\u3092\u76ee\u7684\u3068\u3057\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"#_1","title":"\u898b\u305b\u308b\u7528\u306e\u30da\u30fc\u30b8\u3067\u3059\u3002","text":"1. \u60c5\u5831\u306e\u30b5\u30a4\u30ed\u53162. \u66f4\u65b0\u30b3\u30b9\u30c83. \u30ac\u30d0\u30ca\u30f3\u30b9 <p>\u5404\u90e8\u7f72\u306b\u6563\u3089\u3070\u3063\u305fWord\u3084Excel\u3092\u3001\u5358\u4e00\u306e\u691c\u7d22\u53ef\u80fd\u306a\u30dd\u30fc\u30bf\u30eb\u3078\u96c6\u7d04\u3057\u307e\u3059\u3002</p> <p>\u624b\u52d5\u306ePDF\u5909\u63db\u3084\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u4f5c\u696d\u3092\u81ea\u52d5\u5316\u3002\u30a8\u30f3\u30b8\u30cb\u30a2\u304c\u300c\u66f8\u304f\u300d\u3060\u3051\u3067\u5168\u793e\u306b\u516c\u958b\u3055\u308c\u307e\u3059\u3002</p> <p>\u300c\u8ab0\u304c\u3001\u3044\u3064\u3001\u306a\u305c\u5909\u66f4\u3057\u305f\u304b\u300d\u3092Git\u5c65\u6b74\u3067100%\u8ffd\u8de1\u53ef\u80fd\u306b\u3057\u307e\u3059\u3002</p>"},{"location":"#_2","title":"\u30c0\u30df\u30fc\u306e\u4e2d\u30bf\u30a4\u30c8\u30eb","text":"<ul> <li>\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u306e\u4f5c\u6210: \u826f\u597d (\u6700\u7d42\u66f4\u65b0: 2\u6642\u9593\u524d)</li> <li>\u81ea\u52d5\u5316\u5177\u5408: 85%</li> <li>\u52c7\u6c17: 100% (\u30de\u30eb\u30c1\u30c7\u30d0\u30a4\u30b9\u5bfe\u5fdc)</li> </ul>"},{"location":"kitei/a/","title":"A\u898f\u5b9a","text":""},{"location":"kitei/a/#_1","title":"\u76ee\u7684","text":"<p>\u306f\u3058\u3081\u306b \u3053\u308c\u306f\u76ee\u7684\u3067\u3059</p> <p>\u3053\u308c\u306fA\u898f\u5b9a\u306e\u76ee\u7684\u3068\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"kitei/a/#_2","title":"\u671f\u9650","text":"<ul> <li>\u671f\u9650\u306b\u3064\u3044\u3066</li> <li>\u3044\u3064\u307e\u3067\u304b</li> </ul> <p>\u3044\u3064\u306b\u3059\u308b\u304b</p> \u3053\u3053\u306b\u8a18\u8f09\u3059\u308b <p>\u4f55\u3092\u66f8\u3051\u3070\u3044\u3044\u306e\u304b</p>"},{"location":"kitei/a/#_3","title":"\u57fa\u6e96","text":"<p>\u57fa\u6e96\u306f\u6b21\u306e\u3068\u304a\u308a\u3068\u3059\u308b</p> <pre><code>import pandas as pd\nimport numpy as np\n</code></pre> <pre><code>import { useState } from 'react'\n\nfunction a = async() =&gt; {\n    return(\"console.log\")\n}\nexport default a\n</code></pre>"},{"location":"kitei/a/#_4","title":"\u5185\u5bb9","text":"<p>\u8a73\u7d30\u3067\u3059\u3002</p>"},{"location":"kitei/a/#1","title":"\u305d\u306e\uff11","text":"<p>\u30a4\u30f3\u30bf\u30fc\u30cd\u30c3\u30c8\u3067\u6b21\u306e\u30ad\u30fc\u30ef\u30fc\u30c9\u3092URL\u306b\u30a2\u30af\u30bb\u30b9\u3057\u3066\u304f\u3060\u3055\u3044\u3002 <pre><code>https://www.google.co.jp/\n</code></pre></p>"},{"location":"kitei/a/#11","title":"\u305d\u306e\uff11\u2212\uff11","text":"<p>\u306a\u3057\u3067\u3059\u3002</p>"},{"location":"kitei/a/#2","title":"\u305d\u306e\uff12","text":"<p>\u4f55\u304c</p>"},{"location":"kitei/a/#21","title":"\u305d\u306e\uff12\u2212\uff11","text":"<p>\u3042\u308a\u307e\u305b\u3093\u3002</p> <p>\u7d42\u308f\u308a</p> <p>\u3084\u3063\u3071\u308a\u7d42\u308f\u308a\u307e\u305b\u3093\u3002</p> <p>\u65b0\u3057\u3044\u898f\u5b9a\u3092\u4f5c\u308d\u3046\u3068\u601d\u3044\u307e\u3059\u3002</p>"},{"location":"operation/workflow/","title":"\u66f4\u65b0\u30d7\u30ed\u30bb\u30b9\u3068\u81ea\u52d5\u5316","text":"<p>\u7d4c\u55b6\u5c64\u304c\u61f8\u5ff5\u3059\u308b\u300c\u904b\u7528\u306e\u624b\u9593\u300d\u3092\u3001\u81ea\u52d5\u5316\uff08CI/CD\uff09\u3067\u89e3\u6c7a\u3057\u3066\u3044\u308b\u3053\u3068\u3092\u793a\u3057\u307e\u3059\u3002</p> <pre><code>graph LR\n    A[\u57f7\u7b46\u8005\u304cMarkdown\u3092\u7de8\u96c6] --&gt; B[Git\u3078Push]\n    B --&gt; C{\u81ea\u52d5\u30c6\u30b9\u30c8\u30fb\u627f\u8a8d}\n    C --&gt;|\u5408\u683c| D[\u30b5\u30a4\u30c8\u81ea\u52d5\u751f\u6210]\n    D --&gt; E[\u5168\u793e\u54e1\u3078\u516c\u958b]\n\n    style D fill:#f96,stroke:#333,stroke-width:4px</code></pre>"},{"location":"strategy/pain_points/","title":"\u5f93\u6765\u624b\u6cd5\u3068\u306e\u30b3\u30b9\u30c8\u6bd4\u8f03\u5206\u6790","text":"<p>\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u4f5c\u6210\u30fb\u7ba1\u7406\u306b\u304b\u304b\u308b\u5e74\u9593\u5de5\u6570\u306e\u8a66\u7b97\u3067\u3059\u3002</p> \u9805\u76ee \u5f93\u6765\u306eOffice\u7ba1\u7406 Doc as a Code \u6539\u5584\u7387 \u691c\u7d22\u30fb\u53c2\u7167\u6642\u9593 120\u6642\u9593/\u5e74 20\u6642\u9593/\u5e74 83%\u524a\u6e1b \u30d5\u30a9\u30fc\u30de\u30c3\u30c8\u8abf\u6574 40\u6642\u9593/\u5e74 0\u6642\u9593/\u5e74 100%\u524a\u6e1b \u627f\u8a8d\u30fb\u516c\u958b\u30d5\u30ed\u30fc 1\u9031\u9593 1\u6642\u9593\u4ee5\u5185 98%\u77ed\u7e2e <p>\u30b3\u30b9\u30c8\u306e\u518d\u6295\u8cc7</p> <p>\u524a\u6e1b\u3055\u308c\u305f\u6642\u9593\u306f\u3001\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u306e\u300c\u6574\u5f62\u300d\u3067\u306f\u306a\u304f\u300c\u5185\u5bb9\u306e\u5145\u5b9f\u300d\u306b\u5145\u3066\u308b\u3053\u3068\u304c\u53ef\u80fd\u306b\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"strategy/roadmap/","title":"IT\u6295\u8cc7\u30fb\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u57fa\u76e4\u30ed\u30fc\u30c9\u30de\u30c3\u30d7","text":"<p>\u672c\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306f\u3001\u5358\u306a\u308b\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30c4\u30fc\u30eb\u306e\u5c0e\u5165\u3067\u306f\u306a\u304f\u3001\u300c\u4f01\u696d\u306e\u77e5\u7684\u8ca1\u7523\u3092\u30c7\u30b8\u30bf\u30eb\u8cc7\u7523\u5316\u3059\u308b\u300d\u305f\u3081\u306e3\u30ab\u5e74\u8a08\u753b\u3067\u3059\u3002</p>"},{"location":"strategy/roadmap/#_1","title":"\u30ed\u30fc\u30c9\u30de\u30c3\u30d7","text":""},{"location":"strategy/roadmap/#short-term-year-1","title":"Short-term: \u57fa\u76e4\u78ba\u7acb (Year 1)","text":"<ul> <li>Doc as a Code\u74b0\u5883\u306e\u69cb\u7bc9: Markdown + Git\u306b\u3088\u308b\u57f7\u7b46\u74b0\u5883\u306e\u5168\u793e\u6a19\u6e96\u5316\u3002</li> <li>\u6280\u8853\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u306e\u79fb\u884c: PDF\u3084\u793e\u5185Wiki\u306b\u6563\u5728\u3059\u308b\u91cd\u8981\u60c5\u5831\u306e\u96c6\u7d04\u3002</li> <li>CI/CD\u81ea\u52d5\u5316: \u4fee\u6b63\u304b\u3089\u516c\u958b\u307e\u3067\u306e\u5b8c\u5168\u81ea\u52d5\u5316\u30d7\u30ed\u30bb\u30b9\u306e\u7a3c\u50cd\u3002</li> </ul>"},{"location":"strategy/roadmap/#mid-term-year-2","title":"Mid-term: \u30ca\u30ec\u30c3\u30b8\u30a8\u30b3\u30b7\u30b9\u30c6\u30e0\u5f62\u6210 (Year 2)","text":"<ul> <li>AI\u30c1\u30e3\u30c3\u30c8\u30dc\u30c3\u30c8\u9023\u643a: \u84c4\u7a4d\u3055\u308c\u305fMarkdown\u30c7\u30fc\u30bf\u3092\u5b66\u7fd2\u3055\u305b\u3001\u793e\u5185\u898f\u5b9a\u306b\u5373\u7b54\u3059\u308bAI\u3092\u5c0e\u5165\u3002</li> <li>\u5168\u90e8\u7f72\u3078\u306e\u5c55\u958b: \u4eba\u4e8b\u30fb\u6cd5\u52d9\u898f\u5b9a\u306a\u3069\u3001\u975e\u30a8\u30f3\u30b8\u30cb\u30a2\u90e8\u9580\u3078\u306e\u9069\u7528\u62e1\u5927\u3002</li> <li>\u5206\u6790\u30c0\u30c3\u30b7\u30e5\u30dc\u30fc\u30c9: \u3069\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u304c\u983b\u7e41\u306b\u53c2\u7167\u3055\u308c\u3066\u3044\u308b\u304b\u3092\u53ef\u8996\u5316\u3002</li> </ul>"},{"location":"strategy/roadmap/#long-term-year-3","title":"Long-term: \u77e5\u7684\u8cc7\u7523\u306e\u5b8c\u5168\u540c\u671f (Year 3)","text":"<ul> <li>\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u30fb\u30ac\u30d0\u30ca\u30f3\u30b9: \u4ed5\u69d8\u5909\u66f4\u3068\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u66f4\u65b0\u304c\u5b8c\u5168\u306b\u540c\u671f\u3059\u308b\u4f53\u5236\u306e\u78ba\u7acb\u3002</li> <li>\u5916\u90e8\u516c\u958b\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u5316: \u9867\u5ba2\u5411\u3051\u30de\u30cb\u30e5\u30a2\u30eb\u3084API\u30ea\u30d5\u30a1\u30ec\u30f3\u30b9\u3092\u672c\u57fa\u76e4\u304b\u3089\u76f4\u63a5\u914d\u4fe1\u3002</li> </ul>"},{"location":"strategy/roadmap/#roi","title":"\u671f\u5f85\u3055\u308c\u308b\u6295\u8cc7\u5bfe\u52b9\u679c (ROI)","text":"\u30d5\u30a7\u30fc\u30ba \u4e3b\u306a\u52b9\u679c \u524a\u6e1b\u63a8\u5b9a\u30b3\u30b9\u30c8 (\u5e74\u9593) \u7b2c1\u671f \u691c\u7d22\u30fb\u7ba1\u7406\u5de5\u6570\u306e\u524a\u6e1b \u00a55,000,000 \u7b2c2\u671f \u6559\u80b2\u30fb\u30aa\u30f3\u30dc\u30fc\u30c7\u30a3\u30f3\u30b0\u306e\u52b9\u7387\u5316 \u00a512,000,000 \u7b2c3\u671f \u60c5\u5831\u6f0f\u6d29\u30fb\u4e0d\u6574\u5408\u30ea\u30b9\u30af\u306e\u56de\u907f \u8a08\u6e2c\u4e0d\u80fd\u306a\u9577\u671f\u7684\u5229\u76ca <p>\u5c06\u6765\u306e\u30d3\u30b8\u30e7\u30f3</p> <p>\u300c\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3092\u63a2\u3059\u6642\u9593\u300d\u3092\u30bc\u30ed\u306b\u3057\u3001\u300c\u65b0\u3057\u3044\u4fa1\u5024\u3092\u5275\u9020\u3059\u308b\u6642\u9593\u300d\u3092\u6700\u5927\u5316\u3057\u307e\u3059\u3002</p>"},{"location":"tech/security/","title":"\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u898f\u5b9a\u30fb\u6280\u8853\u30ac\u30d0\u30ca\u30f3\u30b9","text":"<p>\u7d4c\u55b6\u57fa\u76e4\u3068\u3057\u3066\u306e\u4fe1\u983c\u6027\u3092\u62c5\u4fdd\u3059\u308b\u305f\u3081\u3001\u4ee5\u4e0b\u306e\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u30ec\u30a4\u30e4\u30fc\u3092\u5b9f\u88c5\u3057\u307e\u3059\u3002</p>"},{"location":"tech/security/#3","title":"3\u5c64\u306e\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u69cb\u9020","text":""},{"location":"tech/security/#1-iam","title":"1. \u30a2\u30af\u30bb\u30b9\u5236\u5fa1 (IAM)","text":"<ul> <li>\u8a8d\u8a3c\u57fa\u76e4\u9023\u643a: Azure AD / Okta\u7b49\u3068\u306e\u9023\u643a\u306b\u3088\u308a\u3001\u30b7\u30f3\u30b0\u30eb\u30b5\u30a4\u30f3\u30aa\u30f3 (SSO) \u3092\u5b9f\u73fe\u3002</li> <li>\u6a29\u9650\u306e\u7d30\u5206\u5316: <ul> <li><code>\u95b2\u89a7\u8005</code>: \u5168\u793e\u54e1</li> <li><code>\u7de8\u96c6\u8005</code>: \u5404\u90e8\u7f72\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u62c5\u5f53\u8005</li> <li><code>\u627f\u8a8d\u8005</code>: \u90e8\u9580\u8cac\u4efb\u8005 (\u30de\u30fc\u30b8\u6a29\u9650\u4fdd\u6301\u8005)</li> </ul> </li> </ul>"},{"location":"tech/security/#2","title":"2. \u30c7\u30fc\u30bf\u306e\u6a5f\u5bc6\u6027\u3068\u6574\u5408\u6027","text":"<ul> <li>\u5909\u66f4\u5c65\u6b74\u306e\u5b8c\u5168\u4fdd\u6301: Git\u306b\u3088\u308a\u300c\u8ab0\u304c\u3044\u3064\u3069\u306e\u6587\u5b57\u3092\u5909\u66f4\u3057\u305f\u304b\u300d\u3092\u6c38\u4e45\u306b\u8a18\u9332\u3002\u6539\u3056\u3093\u306f\u4e0d\u53ef\u80fd\u3067\u3059\u3002</li> <li>\u8106\u5f31\u6027\u30b9\u30ad\u30e3\u30f3: \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u5185\u306b\u6a5f\u5bc6\u60c5\u5831\uff08\u30d1\u30b9\u30ef\u30fc\u30c9\u3084API\u30ad\u30fc\u306a\u3069\uff09\u304c\u6df7\u5165\u3057\u3066\u3044\u306a\u3044\u304b\u3001\u30b3\u30df\u30c3\u30c8\u6642\u306b\u81ea\u52d5\u691c\u77e5\u3057\u307e\u3059\u3002</li> </ul>"},{"location":"tech/security/#3_1","title":"3. \u7269\u7406\u7684\u30fb\u8ad6\u7406\u7684\u4fdd\u8b77","text":"H \u304a\u3088\u3073 HAMA \u306b\u3064\u3044\u3066 <p>\u30a6\u30a7\u30d6\u30b5\u30a4\u30c8\u304a\u3088\u3073 SNS \u306b\u8a18\u8f09\u3057\u3066\u3044\u308b\u5185\u5bb9\u306e\u6b63\u8aa4\u306b\u3064\u3044\u3066\u306f\u4e00\u5207\u306e\u8cac\u4efb\u3092\u8ca0\u3044\u307e\u305b\u3093\u3002 \u60c5\u5831\u63d0\u4f9b\u306e\u307f\u3092\u76ee\u7684\u3068\u3057\u3066\u304a\u308a\u3001\u60c5\u5831\u306e\u53d6\u308a\u6271\u3044\u306b\u3064\u3044\u3066\u306f\u5404\u81ea\u306e\u8cac\u4efb\u306b\u3066\u53d6\u308a\u6271\u3044\u304f\u3060\u3055\u3044\u3002 \u307e\u305f\u3001\u7b46\u8005\u306e\u3044\u304b\u306a\u308b\u6240\u5c5e\u7d44\u7e54\u3068\u3082\u4e00\u5207\u306e\u95a2\u4fc2\u306f\u306a\u304f\u3001\u6240\u5c5e\u7d44\u7e54\u306b\u95a2\u9023\u3059\u308b\u554f\u3044\u5408\u308f\u305b\u3082\u53d7\u3051\u4ed8\u3051\u307e\u305b\u3093\u3002</p> <pre><code>graph TD\n    User((\u30e6\u30fc\u30b6\u30fc)) --&gt; WAF[WAF / Firewall]\n    WAF --&gt; Auth{\u8a8d\u8a3c\u8a8d\u53ef}\n    Auth --&gt; Web[\u6697\u53f7\u5316\u901a\u4fe1 TLS 1.3]\n    Web --&gt; Repo[(\u6697\u53f7\u5316\u30b9\u30c8\u30ec\u30fc\u30b8)]</code></pre>"},{"location":"tech/standards/","title":"\u958b\u767a\u30fb\u904b\u7528\u6a19\u6e96","text":"<p>\u6a19\u6e96\u5316\u306e\u30e1\u30ea\u30c3\u30c8</p> <p>\u30c7\u30b6\u30a4\u30f3\u306e\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u5316\u306b\u3088\u308a\u3001\u4f5c\u6210\u8005\u306b\u3088\u308b\u300c\u898b\u305f\u76ee\u306e\u3070\u3089\u3064\u304d\u300d\u3092\u30bc\u30ed\u306b\u3057\u307e\u3059\u3002</p> <p>\u3067\u3059\u304c\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u306f\u3042\u308a\u307e\u305b\u3093\u3002</p> \u6a19\u6e96\u5316\u306e\u30c7\u30e1\u30ea\u30c3\u30c8 <p>\u30c7\u30b6\u30a4\u30f3\u306e\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u5316\u306b\u3088\u308a\u3001\u4f5c\u6210\u8005\u306b\u3088\u308b\u300c\u898b\u305f\u76ee\u306e\u3070\u3089\u3064\u304d\u300d\u3092\u30bc\u30ed\u306b\u3057\u307e\u3059\u3002 \u3067\u3059\u304c\u3001\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u306f\u3042\u308a\u307e\u305b\u3093\u3002</p> <p>\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u73fe\u72b6</p> <p>\u73fe\u5728\u306e\u30d5\u30a7\u30fc\u30ba\u306f\u300c\u30d7\u30ed\u30c8\u30bf\u30a4\u30d7\u69cb\u7bc9\u300d\u3067\u3059\u3002</p> <p>\u6d3b\u7528\u6cd5</p> <p>\u793e\u5185Wiki\u306e\u4ee3\u308f\u308a\u3068\u3057\u3066\u3001\u30ce\u30a6\u30cf\u30a6\u3092\u84c4\u7a4d\u3059\u308b\u306e\u306b\u6700\u9069\u3067\u3059\u3002</p> <ul> <li> \u30a4\u30f3\u30d5\u30e9\u74b0\u5883\u306e\u69cb\u7bc9</li> <li> mkdocs.yml \u306e\u57fa\u672c\u8a2d\u5b9a</li> <li> \u5168\u793e\u54e1\u3078\u306e\u516c\u958b\u30fb\u5468\u77e5</li> </ul>"},{"location":"tech/standards/#_2","title":"\u30b3\u30fc\u30c9\u30b9\u30cb\u30da\u30c3\u30c8\u306e\u7ba1\u7406","text":"<p>\u6280\u8853\u8cc7\u7523\u3082\u3053\u306e\u3088\u3046\u306b\u7f8e\u3057\u304f\u3001\u30b3\u30d4\u30fc\u53ef\u80fd\u306a\u72b6\u614b\u3067\u5171\u6709\u3067\u304d\u307e\u3059\u3002</p> <p><pre><code>def check_governance(doc):\n    if doc.has_approval:\n        return \"\u516c\u958b\u53ef\u80fd\"\n    return \"\u30c9\u30e9\u30d5\u30c8\"\n</code></pre> IT\u6226\u7565\u3092\u78ba\u8a8d\u3059\u308b \u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u898f\u5b9a</p>  \u6295\u8cc7\u5bfe\u52b9\u679c \u30b9\u30d4\u30fc\u30c9 <ul> <li>\u30b3\u30b9\u30c8\u524a\u6e1b: \u5e74\u9593 250\u4e07\u5186 \u76f8\u5f53\u306e\u5de5\u6570\u524a\u6e1b</li> <li>\u8cc7\u7523\u5316: \u5c5e\u4eba\u5316\u3057\u305f\u30ce\u30a6\u30cf\u30a6\u306e\u5171\u6709\u77e5\u5316</li> <li>\u4f55</li> <li>\u3053\u308c</li> <li>\u306a\u3093\u3060\u308d</li> <li>\u6559\u3048\u3066</li> </ul> <ul> <li>\u66f4\u65b0\u901f\u5ea6: \u4fee\u6b63\u304b\u3089\u516c\u958b\u307e\u3067\u6700\u77ed 2\u5206</li> <li>\u691c\u7d22\u6027: \u5168\u6587\u691c\u7d22\u306b\u3088\u308b\u5373\u6642\u30a2\u30af\u30bb\u30b9</li> <li>\u3053\u308c\u3089\u306f\u3059\u3067\u306b\u518d\u73fe\u3055\u308c\u3066\u3044\u307e\u3059\u3002</li> </ul>"}]}